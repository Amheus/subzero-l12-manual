%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% NUMBERED PROCEDURE
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
\newcommand{\manual@steptoken}[1]{%
	\tcbox[on line,boxsep=0pt,left=2.2mm,right=2.2mm,top=0.8mm,bottom=0.8mm,
	arc=1mm,colback=manualaccent,colframe=manualaccent,
	fontupper=\sffamily\bfseries\small\color{white}]{#1}}
\newlist{steps}{enumerate}{1}
\setlist[steps]{label={\protect\manual@steptoken{\arabic*}},
	leftmargin=*,labelsep=0.8em,itemsep=0.6em,topsep=0.5em,
	before=\setlength{\parskip}{0.2em}}





%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% INLINE CONTROL REFERENCE
% For referring to a physical knob/port on the L12.
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
\newcommand{\control}[1]{%
	\tcbox[on line,boxsep=0pt,left=1.4mm,right=1.4mm,top=0.4mm,bottom=0.4mm,
	arc=0.6mm,colback=manualaccentpale,colframe=manualaccent!40,
	boxrule=0.5pt,fontupper=\sffamily\bfseries\footnotesize\color{manualaccentdark}]%
	{\MakeUppercase{#1}}}





%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% INLINE CONNECTOR/PORT REFERENCE
% For referring to a connector/port on the L12, visually distinct from a control.
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
\newcommand{\port}[1]{%
	\tcbox[on line,boxsep=0pt,left=1.4mm,right=1.4mm,top=0.4mm,bottom=0.4mm,
	arc=0.6mm,colback=manualink!4,colframe=manualink!30,
	boxrule=0.5pt,fontupper=\ttfamily\footnotesize\color{manualink}]%
	{#1}}





%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% SPEC TABLE
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
\NewEnviron{spectable}[1][]{%
	\par\vspace{0.4em}%
	\def\manual@spectitle{#1}%
	\ifx\manual@spectitle\empty\else
	{\sffamily\bfseries\footnotesize\color{manualgrey}%
		\MakeUppercase{#1}}\par\vspace{0.2em}%
	\fi
	\renewcommand{\arraystretch}{1.35}%
	\arrayrulecolor{manualaccent}%
	\begin{tabularx}{\linewidth}{%
			>{\columncolor{manualaccentpale}\bfseries\color{manualaccentdark}}p{0.34\linewidth}%
			>{\columncolor{manualaccentpale}\color{manualink}}X}
		\specialrule{2pt}{0pt}{0pt}
		\BODY
		\specialrule{2pt}{0pt}{0pt}
	\end{tabularx}%
	\arrayrulecolor{black}\par\vspace{0.2em}%
}





