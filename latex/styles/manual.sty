%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% PARAGRAPHS
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
\setlength{\parindent}{0pt}
\setlength{\parskip}{0.55em plus 0.1em}
\linespread{1.05}





%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% HEADINGS
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
\titleformat{\section}
{\sffamily\Large\bfseries\color{manualaccent}}
{\thesection}{0.7em}{}
[\vspace{2pt}{\color{manualaccent}\titlerule[1.1pt]}]
\titlespacing*{\section}{0pt}{2.4ex plus .8ex}{1.2ex}

\titleformat{\subsection}
{\sffamily\large\bfseries\color{manualaccentdark}}
{\thesubsection}{0.6em}{}
\titlespacing*{\subsection}{0pt}{2.0ex plus .6ex}{0.8ex}

\titleformat{\subsubsection}
{\sffamily\normalsize\bfseries\color{manualink}}
{\thesubsubsection}{0.6em}{}
\titlespacing*{\subsubsection}{0pt}{1.6ex plus .5ex}{0.6ex}

\@ifundefined{chapter}{}{%
	\titleformat{\chapter}[display]
	{\sffamily\bfseries\color{manualaccent}}
	{\fontsize{14}{16}\selectfont\MakeUppercase{\chaptertitlename}\ \thechapter}
	{6pt}{\Huge}
	[\vspace{4pt}{\color{manualaccent}\titlerule[1.4pt]}]
}





%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% HEADER / FOOTER
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
\pagestyle{fancy}
\fancyhf{}
\renewcommand{\headrulewidth}{0.6pt}
\renewcommand{\footrulewidth}{0pt}
\renewcommand{\headrule}{\hbox to\headwidth{\color{manualrule}\leaders\hrule height \headrulewidth\hfill}}
\fancyhead[L]{\small\color{manualaccentdark}\textbf{\manual@product}\ \textcolor{manualgrey}{\manual@model}}
\fancyhead[R]{\small\color{manualgrey}\nouppercase{\leftmark}}
\fancyfoot[L]{\small\color{manualgrey}v\manual@version}
\fancyfoot[R]{\small\color{manualgrey}Page \thepage\ of \pageref*{LastPage}}

\fancypagestyle{plain}{%
	\fancyhf{}\renewcommand{\headrulewidth}{0pt}%
	\fancyfoot[R]{\small\color{manualgrey}Page \thepage\ of \pageref*{LastPage}}%
}





%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% CAPTIONS
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
\captionsetup{
	font={small,color=manualink},
	labelfont={bf,color=manualaccentdark},
	labelsep=period,
	skip=6pt
}





%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% TITLE PAGE
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
\newcommand{\manualtitlepage}{%
	\begin{titlepage}
		\thispagestyle{empty}
		\raggedright
		\vspace*{1.2cm}
		{\color{manualaccent}\rule{\linewidth}{2.2pt}}\par
		\vspace{1.0cm}
		{\sffamily\fontsize{15}{18}\selectfont\color{manualgrey}%
			USER MANUAL \quad\textbar\quad MODEL \manual@model}\par
		\vspace{0.5cm}
		{\sffamily\fontsize{46}{50}\selectfont\bfseries\color{manualink}\manual@product}\par
		\ifx\manual@tagline\empty\else
		\vspace{0.5cm}
		{\sffamily\Large\color{manualaccentdark}\manual@tagline}\par
		\fi
		\vspace{0.8cm}
		{\color{manualaccent}\rule{\linewidth}{2.2pt}}\par
		\vfill
		\begin{description}[font=\bfseries\color{manualaccentdark},
			leftmargin=0pt,labelsep=0.8em,itemsep=2pt]
			\ifx\manual@version\empty\else\item[Version]\manual@version\fi
			\ifx\manual@author\empty\else\item[Maintained by]\manual@author\fi
			\ifx\manual@licence\empty\else\item[Licence]\manual@licence\fi
		\end{description}
		\vspace{0.6cm}
		{\small\color{manualgrey}This is an independent, community-maintained
			manual and is not affiliated with or endorsed by the manufacturer.\par}
	\end{titlepage}%
}





